---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

// Group posts by series
const seriesMap = new Map<string, typeof allPosts>();
for (const post of allPosts) {
  if (post.data.series) {
    const existing = seriesMap.get(post.data.series) || [];
    existing.push(post);
    seriesMap.set(post.data.series, existing);
  }
}

// Sort posts within each series by seriesOrder
for (const [, posts] of seriesMap) {
  posts.sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0));
}

const seriesMeta: Record<string, { icon: string; description: string; color: string }> = {
  'Transformer Anatomy': {
    icon: '🧬',
    description: 'Every component of a modern LLM explained from first principles. From tokenization to the output head — understand enough to build a transformer from scratch.',
    color: '#a371f7',
  },
  'Inference Optimization Timeline': {
    icon: '🚀',
    description: 'The evolution of LLM inference optimization from 2017 to 2025. KV cache, FlashAttention, PagedAttention, speculative decoding, and beyond.',
    color: '#58a6ff',
  },
  'Frontier Model Architectures': {
    icon: '🔬',
    description: 'How the latest frontier models push boundaries — Kimi K2, MiniMax-01, DeepSeek R1, Qwen 3, and the techniques that define 2025-era LLMs.',
    color: '#f97583',
  },
  'vLLM Internals': {
    icon: '🔧',
    description: 'A source-code-level tour of vLLM — the scheduler, PagedAttention kernels, worker architecture, model runner, and how every optimization fits together.',
    color: '#3fb950',
  },
  'vLLM v1 & Omni Internals': {
    icon: '🔬',
    description: 'Code-first deep dives into vLLM v1 architecture — the redesigned block manager, disaggregated E/P/D/G pipeline, multimodal serving, and the shift to unified scheduling.',
    color: '#39c5cf',
  },
  'NVIDIA Dynamo & llm-d': {
    icon: '🏭',
    description: 'The inference operating system for AI factories — KV-aware routing, ModelExpress GPU-to-GPU streaming, NIXL, and datacenter-scale orchestration.',
    color: '#f59e0b',
  },
  'MoE Masterclass': {
    icon: '🧩',
    description: 'Beyond the simple router — expert parallelism communication, ScMoE overlap techniques, DeepSeek V3 deep dive, and building a gated MoE from scratch.',
    color: '#ef4444',
  },
  'The Dataset Frontier': {
    icon: '📦',
    description: 'Data is the new code — synthetic data pipelines (Magpie, Nemotron-4), web curation (DCLM, FineWeb-Edu), and building training datasets from scratch.',
    color: '#db61a2',
  },
  'Frontier Research 2025-2026': {
    icon: '🔮',
    description: 'The bleeding edge — reasoning scaling laws, inference-time compute budgets, embodied AI foundations, and self-improving systems.',
    color: '#79c0ff',
  },
};

const seriesList = Array.from(seriesMap.entries()).map(([name, posts]) => ({
  name,
  posts,
  meta: seriesMeta[name] || { icon: '📚', description: '', color: '#8b949e' },
}));

// Sort series by a fixed order
const seriesOrder = ['Transformer Anatomy', 'Inference Optimization Timeline', 'Frontier Model Architectures', 'vLLM Internals', 'vLLM v1 & Omni Internals', 'NVIDIA Dynamo & llm-d', 'MoE Masterclass', 'The Dataset Frontier', 'Frontier Research 2025-2026'];
seriesList.sort((a, b) => {
  const ai = seriesOrder.indexOf(a.name);
  const bi = seriesOrder.indexOf(b.name);
  return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
});
---

<BaseLayout
  title="Series"
  description="In-depth multi-part series on LLM architecture, inference optimization, and systems engineering"
>
  <div class="series-page">
    <header class="page-header">
      <div class="container">
        <h1 class="page-title">Series</h1>
        <p class="page-description">
          Deep multi-part explorations designed to build comprehensive understanding.
          Read in order — each post builds on the previous.
        </p>
      </div>
    </header>

    <div class="page-content">
      <div class="container">
        {seriesList.map((series) => (
          <div class="series-block" style={`--accent-color: ${series.meta.color}`}>
            <div class="series-header">
              <span class="series-icon">{series.meta.icon}</span>
              <div class="series-info">
                <h2 class="series-name">{series.name}</h2>
                <p class="series-description">{series.meta.description}</p>
                <span class="series-count">{series.posts.length} parts</span>
              </div>
            </div>

            <ol class="series-posts">
              {series.posts.map((post, index) => (
                <li class="series-post-item">
                  <a href={`/posts/${post.slug}`} class="post-link">
                    <span class="post-number">{index + 1}</span>
                    <div class="post-details">
                      <span class="post-title">{post.data.title}</span>
                      <span class="post-meta">
                        {post.data.difficulty} · {post.data.readingTime || Math.ceil(post.body.split(/\s+/).length / 200)} min read
                      </span>
                    </div>
                  </a>
                </li>
              ))}
            </ol>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style lang="scss">
  @use '../../styles/variables' as *;

  .page-header {
    padding: $space-16 0 $space-10;
    background: $color-bg-secondary;
    border-bottom: 1px solid $color-border-default;
  }

  .page-title {
    font-size: $font-size-3xl;
    margin-bottom: $space-3;
  }

  .page-description {
    font-size: $font-size-lg;
    color: $color-text-secondary;
    margin: 0;
    max-width: 60ch;
  }

  .page-content {
    padding: $space-12 0;
  }

  .series-block {
    margin-bottom: $space-12;
    background: $color-bg-secondary;
    border: 1px solid $color-border-default;
    border-radius: $border-radius-lg;
    overflow: hidden;

    &:hover {
      border-color: var(--accent-color, $color-border-emphasis);
    }
  }

  .series-header {
    display: flex;
    gap: $space-5;
    padding: $space-6;
    background: $color-bg-tertiary;
    border-bottom: 1px solid $color-border-default;
  }

  .series-icon {
    font-size: 2.5rem;
    flex-shrink: 0;
  }

  .series-info {
    flex: 1;
  }

  .series-name {
    font-family: $font-display;
    font-size: $font-size-2xl;
    color: var(--accent-color, $color-text-primary);
    margin: 0 0 $space-2;
  }

  .series-description {
    font-size: $font-size-sm;
    color: $color-text-secondary;
    line-height: $line-height-relaxed;
    margin: 0 0 $space-3;
    max-width: 65ch;
  }

  .series-count {
    font-family: $font-mono;
    font-size: $font-size-xs;
    color: $color-text-tertiary;
    padding: $space-1 $space-2;
    background: $color-bg-secondary;
    border-radius: $border-radius-full;
  }

  .series-posts {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .series-post-item {
    border-bottom: 1px solid $color-border-default;

    &:last-child {
      border-bottom: none;
    }
  }

  .post-link {
    display: flex;
    align-items: center;
    gap: $space-4;
    padding: $space-4 $space-6;
    text-decoration: none;
    transition: background $transition-fast;

    &:hover {
      background: $color-bg-tertiary;
      text-decoration: none;

      .post-title {
        color: var(--accent-color, $color-accent-blue);
      }
    }
  }

  .post-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    font-family: $font-mono;
    font-size: $font-size-sm;
    font-weight: $font-weight-semibold;
    color: $color-text-tertiary;
    background: $color-bg-tertiary;
    border-radius: $border-radius-full;
    flex-shrink: 0;
  }

  .post-details {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .post-title {
    font-size: $font-size-sm;
    font-weight: $font-weight-medium;
    color: $color-text-primary;
    transition: color $transition-fast;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;

    @include respond-to(md) {
      white-space: normal;
    }
  }

  .post-meta {
    font-size: $font-size-xs;
    font-family: $font-mono;
    color: $color-text-tertiary;
  }
</style>
