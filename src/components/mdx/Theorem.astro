---
interface Props {
  title?: string;
  type?: 'Theorem' | 'Lemma' | 'Definition';
}
const { title, type = 'Theorem' } = Astro.props;
---

<div class="theorem-block">
  <div class="theorem-header">
    <span class="theorem-symbol">&#931;</span>
    <strong>{type}{title ? `: ${title}` : ''}</strong>
  </div>
  <div class="theorem-content">
    <slot />
  </div>
</div>

<style lang="scss">
  @use '../../styles/variables' as *;

  .theorem-block {
    margin: $space-8 0;
    border-radius: $border-radius-lg;
    border-left: 4px solid $color-accent-purple;
    background: $color-bg-secondary;
    padding: $space-6;
    box-shadow: $shadow-sm;
  }

  .theorem-header {
    display: flex;
    align-items: center;
    gap: $space-2;
    margin-bottom: $space-2;
    font-family: $font-mono;
    font-size: $font-size-sm;
    text-transform: uppercase;
    letter-spacing: $letter-spacing-widest;
    color: $color-accent-purple;
  }

  .theorem-symbol {
    font-size: $font-size-lg;
  }

  .theorem-content {
    font-style: italic;
    line-height: $line-height-relaxed;
    color: $color-text-primary;

    :global(p:last-child) {
      margin-bottom: 0;
    }

    :global(.katex-display) {
      margin: $space-4 0;
      overflow-x: auto;
    }
  }
</style>
