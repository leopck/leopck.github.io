---
title: "CUDA Warp Visualizer"
description: "Interactive visualization of CUDA warp execution and occupancy patterns"

const uid = "cwv-" + Math.random().toString(36).substring(2, 9);
---

<div class="cuda-occupancy-calculator" id={uid}>
  <h3 class="calc-title">CUDA Occupancy Calculator</h3>

  <div class="calc-grid">
    <div class="calc-inputs">
      <div class="input-group">
        <label>Block Size: <span class="val-block-size">256</span> threads</label>
        <input type="range" class="inp-block-size" min="32" max="1024" step="32" value="256" />
        <p class="input-hint">Must be multiple of 32 (warp size)</p>
      </div>

      <div class="input-group">
        <label>Shared Mem per Block: <span class="val-shared-mem">48</span> KB</label>
        <input type="range" class="inp-shared-mem" min="0" max="96" value="48" />
        <p class="input-hint">Shared memory used per thread block</p>
      </div>

      <div class="input-group">
        <label>Registers per Thread: <span class="val-regs">32</span></label>
        <input type="range" class="inp-regs" min="8" max="255" value="32" />
        <p class="input-hint">Register usage per thread</p>
      </div>
    </div>

    <div class="calc-results">
      <h4>Occupancy Analysis</h4>

      <div class="result-row">
        <span>Warps per Block:</span>
        <span class="result-val val-warps-per-block">8</span>
      </div>
      <div class="result-row">
        <span>Max Theoretical Blocks:</span>
        <span class="result-val val-max-blocks">8</span>
      </div>
      <div class="result-row">
        <span>Achieved Warps per SM:</span>
        <span class="result-val val-achieved-warps">64</span>
      </div>

      <div class="result-highlight">
        <div class="result-row">
          <span>Occupancy:</span>
          <span class="result-val val-occupancy">100.0%</span>
        </div>
        <div class="result-bottleneck">
          <strong>Bottleneck:</strong> <span class="val-bottleneck">Hardware Limit</span>
        </div>
      </div>

      <div class="result-tip">
        <strong>Optimization Tip:</strong> Aim for 50-100% occupancy. Consider reducing register usage or adjusting block size to improve occupancy.
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ uid }}>
(function() {
  const root = document.getElementById(uid);
  if (!root) return;

  const inpBlockSize = root.querySelector('.inp-block-size');
  const inpSharedMem = root.querySelector('.inp-shared-mem');
  const inpRegs = root.querySelector('.inp-regs');

  function update() {
    const blockSize = parseInt(inpBlockSize.value);
    const sharedMemPerBlock = parseInt(inpSharedMem.value);
    const registersPerThread = parseInt(inpRegs.value);

    root.querySelector('.val-block-size').textContent = blockSize;
    root.querySelector('.val-shared-mem').textContent = sharedMemPerBlock;
    root.querySelector('.val-regs').textContent = registersPerThread;

    const warpsPerBlock = Math.ceil(blockSize / 32);
    const blocksBySharedMem = sharedMemPerBlock > 0 ? Math.floor(64 / sharedMemPerBlock) : 32;
    const blocksByRegs = Math.floor(65536 / (registersPerThread * blockSize));
    const blocksByMaxLimit = 32;
    const maxWarpsPerSM = 64;

    const theoreticalBlocks = Math.min(blocksBySharedMem, blocksByRegs, blocksByMaxLimit);
    const theoreticalWarps = theoreticalBlocks * warpsPerBlock;
    const achievedWarps = Math.min(theoreticalWarps, maxWarpsPerSM);
    const occupancy = (achievedWarps / maxWarpsPerSM) * 100;

    const minVal = Math.min(blocksBySharedMem, blocksByRegs, blocksByMaxLimit);
    let bottleneck = "Hardware Limit";
    if (minVal === blocksBySharedMem) bottleneck = "Shared Memory";
    else if (minVal === blocksByRegs) bottleneck = "Registers";

    root.querySelector('.val-warps-per-block').textContent = warpsPerBlock;
    root.querySelector('.val-max-blocks').textContent = theoreticalBlocks;
    root.querySelector('.val-achieved-warps').textContent = achievedWarps;
    root.querySelector('.val-occupancy').textContent = occupancy.toFixed(1) + '%';
    root.querySelector('.val-bottleneck').textContent = bottleneck;
  }

  inpBlockSize.addEventListener('input', update);
  inpSharedMem.addEventListener('input', update);
  inpRegs.addEventListener('input', update);
  update();
})();
</script>

<style lang="scss">
  @use '../../styles/variables' as *;

  .cuda-occupancy-calculator {
    margin: $space-8 0;
    padding: $space-6;
    background: $color-bg-secondary;
    border: 1px solid $color-border-default;
    border-radius: $border-radius-lg;
  }

  .calc-title {
    font-family: $font-mono;
    font-size: $font-size-lg;
    font-weight: $font-weight-bold;
    margin-bottom: $space-6;
    color: $color-text-primary;
  }

  .calc-grid {
    display: grid;
    gap: $space-6;
    @media (min-width: $breakpoint-md) {
      grid-template-columns: 1fr 1fr;
    }
  }

  .input-group {
    margin-bottom: $space-4;

    label {
      display: block;
      font-size: $font-size-sm;
      font-weight: $font-weight-medium;
      color: $color-text-secondary;
      margin-bottom: $space-1;
    }

    input[type="range"] {
      width: 100%;
      height: 6px;
      border-radius: 3px;
      background: $color-bg-tertiary;
      outline: none;
      appearance: none;

      &::-webkit-slider-thumb {
        appearance: none;
        height: 18px;
        width: 18px;
        border-radius: 50%;
        background: $color-accent-blue;
        cursor: pointer;
      }

      &::-moz-range-thumb {
        height: 18px;
        width: 18px;
        border-radius: 50%;
        background: $color-accent-blue;
        cursor: pointer;
        border: none;
      }
    }
  }

  .input-hint {
    font-size: $font-size-xs;
    color: $color-text-tertiary;
    margin-top: $space-1;
  }

  .calc-results {
    background: $color-bg-tertiary;
    padding: $space-4;
    border-radius: $border-radius-md;
    border: 1px solid $color-border-default;

    h4 {
      font-weight: $font-weight-semibold;
      margin-bottom: $space-3;
      color: $color-text-primary;
    }
  }

  .result-row {
    display: flex;
    justify-content: space-between;
    font-size: $font-size-sm;
    color: $color-text-secondary;
    margin-bottom: $space-2;
  }

  .result-val {
    font-family: $font-mono;
    color: $color-text-primary;
  }

  .result-highlight {
    border-top: 1px solid $color-border-default;
    padding-top: $space-3;
    margin-top: $space-3;

    .result-val {
      font-size: $font-size-lg;
      font-weight: $font-weight-semibold;
      color: $color-accent-blue;
    }
  }

  .result-bottleneck {
    margin-top: $space-2;
    padding: $space-2;
    background: rgba($color-accent-orange, 0.1);
    border-radius: $border-radius-sm;
    font-size: $font-size-xs;
    color: $color-accent-orange;
  }

  .result-tip {
    margin-top: $space-4;
    padding: $space-3;
    background: rgba($color-accent-blue, 0.1);
    border-radius: $border-radius-sm;
    font-size: $font-size-xs;
    color: $color-accent-blue;
  }
</style>
