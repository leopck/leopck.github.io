---
const uid = "epo-" + Math.random().toString(36).substring(2, 9);
---

<div class="esp32-power-calculator" id={uid}>
  <h3 class="calc-title">ESP32 Power Consumption Calculator</h3>

  <div class="calc-grid">
    <div class="calc-inputs">
      <div class="input-group">
        <label>Active Current (mA): <span class="val-active">200</span></label>
        <input type="range" class="inp-active" min="50" max="300" value="200" />
        <p class="input-hint">During WiFi transmission/reception</p>
      </div>

      <div class="input-group">
        <label>Sleep Current (uA): <span class="val-sleep">15.0</span></label>
        <input type="range" class="inp-sleep" min="1" max="50" value="15" />
        <p class="input-hint">During deep sleep mode</p>
      </div>

      <div class="input-group">
        <label>Active Time (sec): <span class="val-active-time">3</span></label>
        <input type="range" class="inp-active-time" min="1" max="30" value="3" />
        <p class="input-hint">Duration of high-power operations</p>
      </div>

      <div class="input-group">
        <label>Sleep Time (sec): <span class="val-sleep-time">3597</span></label>
        <input type="range" class="inp-sleep-time" min="100" max="7200" value="3597" />
        <p class="input-hint">Duration between active cycles</p>
      </div>

      <div class="input-group">
        <label>Battery Capacity (mAh): <span class="val-battery">2000</span></label>
        <input type="range" class="inp-battery" min="500" max="5000" value="2000" />
        <p class="input-hint">Battery capacity for life estimation</p>
      </div>
    </div>

    <div class="calc-results">
      <h4>Power Analysis Results</h4>

      <div class="result-row">
        <span>Average Current:</span>
        <span class="result-val val-avg-current">---</span>
      </div>
      <div class="result-row">
        <span>Active Charge per Cycle:</span>
        <span class="result-val val-active-charge">---</span>
      </div>
      <div class="result-row">
        <span>Sleep Charge per Cycle:</span>
        <span class="result-val val-sleep-charge">---</span>
      </div>

      <div class="result-highlight">
        <div class="result-row">
          <span>Battery Life:</span>
          <span class="result-val val-days">---</span>
        </div>
        <div class="result-row">
          <span>Or approximately:</span>
          <span class="result-val val-years">---</span>
        </div>
      </div>

      <div class="result-tip">
        <strong>Tip:</strong> Reducing active time while maintaining long sleep cycles can significantly extend battery life. Consider batching operations and optimizing transmission efficiency.
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ uid }}>
(function() {
  const root = document.getElementById(uid);
  if (!root) return;

  const inps = {
    active: root.querySelector('.inp-active'),
    sleep: root.querySelector('.inp-sleep'),
    activeTime: root.querySelector('.inp-active-time'),
    sleepTime: root.querySelector('.inp-sleep-time'),
    battery: root.querySelector('.inp-battery'),
  };

  function update() {
    const activeCurrent = parseFloat(inps.active.value);
    const sleepCurrentUA = parseFloat(inps.sleep.value);
    const sleepCurrent = sleepCurrentUA / 1000;
    const activeTime = parseInt(inps.activeTime.value);
    const sleepTime = parseInt(inps.sleepTime.value);
    const batteryCapacity = parseInt(inps.battery.value);

    root.querySelector('.val-active').textContent = activeCurrent;
    root.querySelector('.val-sleep').textContent = sleepCurrentUA.toFixed(1);
    root.querySelector('.val-active-time').textContent = activeTime;
    root.querySelector('.val-sleep-time').textContent = sleepTime;
    root.querySelector('.val-battery').textContent = batteryCapacity;

    const activeCharge = (activeCurrent * activeTime) / 3600;
    const sleepCharge = (sleepCurrent * sleepTime) / 3600;
    const totalCycleCharge = activeCharge + sleepCharge;
    const avgCurrent = ((activeCharge + sleepCharge) * 3600) / (activeTime + sleepTime);

    const totalCycles = batteryCapacity / totalCycleCharge;
    const totalSeconds = totalCycles * (activeTime + sleepTime);
    const days = totalSeconds / (24 * 3600);
    const years = days / 365.25;

    root.querySelector('.val-avg-current').textContent = avgCurrent.toFixed(3) + ' mA';
    root.querySelector('.val-active-charge').textContent = activeCharge.toFixed(4) + ' mAh';
    root.querySelector('.val-sleep-charge').textContent = sleepCharge.toFixed(4) + ' mAh';
    root.querySelector('.val-days').textContent = days.toFixed(1) + ' days';
    root.querySelector('.val-years').textContent = years.toFixed(2) + ' years';
  }

  Object.values(inps).forEach(function(inp) { inp.addEventListener('input', update); });
  update();
})();
</script>

<style lang="scss">
  @use '../../styles/variables' as *;

  .esp32-power-calculator {
    margin: $space-8 0;
    padding: $space-6;
    background: $color-bg-secondary;
    border: 1px solid $color-border-default;
    border-radius: $border-radius-lg;
  }

  .calc-title {
    font-family: $font-mono;
    font-size: $font-size-lg;
    font-weight: $font-weight-bold;
    margin-bottom: $space-6;
    color: $color-text-primary;
  }

  .calc-grid {
    display: grid;
    gap: $space-6;
    @media (min-width: $breakpoint-md) {
      grid-template-columns: 1fr 1fr;
    }
  }

  .input-group {
    margin-bottom: $space-4;

    label {
      display: block;
      font-size: $font-size-sm;
      font-weight: $font-weight-medium;
      color: $color-text-secondary;
      margin-bottom: $space-1;
    }

    input[type="range"] {
      width: 100%;
      height: 6px;
      border-radius: 3px;
      background: $color-bg-tertiary;
      outline: none;
      appearance: none;

      &::-webkit-slider-thumb {
        appearance: none;
        height: 18px;
        width: 18px;
        border-radius: 50%;
        background: $color-accent-green;
        cursor: pointer;
      }

      &::-moz-range-thumb {
        height: 18px;
        width: 18px;
        border-radius: 50%;
        background: $color-accent-green;
        cursor: pointer;
        border: none;
      }
    }
  }

  .input-hint {
    font-size: $font-size-xs;
    color: $color-text-tertiary;
    margin-top: $space-1;
  }

  .calc-results {
    background: $color-bg-tertiary;
    padding: $space-4;
    border-radius: $border-radius-md;
    border: 1px solid $color-border-default;

    h4 {
      font-weight: $font-weight-semibold;
      margin-bottom: $space-3;
      color: $color-text-primary;
    }
  }

  .result-row {
    display: flex;
    justify-content: space-between;
    font-size: $font-size-sm;
    color: $color-text-secondary;
    margin-bottom: $space-2;
  }

  .result-val {
    font-family: $font-mono;
    color: $color-text-primary;
  }

  .result-highlight {
    border-top: 1px solid $color-border-default;
    padding-top: $space-3;
    margin-top: $space-3;

    .result-val {
      font-weight: $font-weight-semibold;
      color: $color-accent-green;
    }
  }

  .result-tip {
    margin-top: $space-4;
    padding: $space-3;
    background: rgba($color-accent-blue, 0.1);
    border-radius: $border-radius-sm;
    font-size: $font-size-xs;
    color: $color-accent-blue;
  }
</style>
